--- !u!102 &1743254459
TextMesh:
  serializedVersion: 3
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1743254457}
  m_Text: "This sandy biome is an example of \n\"fill in the hollow parts\" of the
    base mountainous biome.\n- Height blend: Keep Higher, as it is intended to hide
    the hollow region\n- Texture blend: Height Win, as color should only appear where
    height map is actually occupied by this biome. \n  In Replace mode, color will
    bleed.\n- Population blend: Height Win, similar to texture, tree and grass should
    only appear where geometry occupied by this biome.\n\nTry:\n- Enable Use Transform
    for Height Blend.\n- Move the biome up/down, scale it up/down to see how it behave."
  m_OffsetZ: 0
  m_CharacterSize: 1
  m_LineSpacing: 1
  m_Anchor: 0
  m_Alignment: 0
  m_TabSize: 4
  m_FontSize: 32
  m_FontStyle: 0
  m_RichText: 1
  m_Font: {fileID: 10102, guid: 0000000000000000e000000000000000, type: 0}
