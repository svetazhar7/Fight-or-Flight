--- !u!102 &1392337481
TextMesh:
  serializedVersion: 3
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1392337479}
  m_Text: 'This oasis biome was placed on top of the sand dunes.

    - Height blend
    is Replace (not Lower) because the height map models the pond as negative values.

    -
    Biome transform taken into account for mix and match with other biomes geometry.

    -
    Texture and polulation blend set as Replace.

    This is the example of "gradually
    change from one to other biome".'
  m_OffsetZ: 0
  m_CharacterSize: 1
  m_LineSpacing: 1
  m_Anchor: 0
  m_Alignment: 0
  m_TabSize: 4
